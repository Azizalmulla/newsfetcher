# Application
APP_ENV=development
APP_NAME=newsfetcher
LOG_LEVEL=INFO
LOG_JSON=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# PostgreSQL
# Local Compose uses port 5433. Railway injects DATABASE_URL (postgres:// is auto-normalized).
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=newsfetcher
POSTGRES_USER=newsfetcher
POSTGRES_PASSWORD=newsfetcher_dev_password
DATABASE_URL=postgresql+psycopg://newsfetcher:newsfetcher_dev_password@localhost:5433/newsfetcher

# Redis / Celery
# On Railway, set REDIS_URL=${{Redis.REDIS_URL}}; Celery falls back to REDIS_URL if unset.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# S3-compatible object storage (MinIO locally)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=newsfetcher
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/tmp/newsfetcher-storage

# Email delivery for approved reports
EMAIL_BACKEND=file
EMAIL_FILE_DIR=/tmp/newsfetcher-mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@newsfetcher.local
SMTP_USE_TLS=true

# Observability (optional in Phase 0)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=newsfetcher-api
OTEL_TRACES_EXPORTER=none
PROMETHEUS_METRICS_ENABLED=true

# OCR — pin confirmed Mistral OCR 4 model ID before Phase 7 production use
OCR_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=

# Embeddings / rerank — verify against live Voyage account before production
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-4-large
EMBEDDING_DIMENSIONS=1024
EMBEDDING_FALLBACK_LOCAL=true
VOYAGE_API_KEY=
RERANK_PROVIDER=voyage
RERANK_MODEL=rerank-2.5
SEMANTIC_TOP_K=20
SEMANTIC_RERANK_TOP_K=10
SEMANTIC_MIN_COSINE=0.45
SEMANTIC_MIN_RERANK=0.10

# LLM intelligence layer — DeepSeek V4 (OpenAI-compatible)
# Prefer deepseek-v4-flash for bulk Arabic matching/classification (cost + speed).
# Use deepseek-v4-pro for hard ambiguous review / agent tasks.
# Legacy deepseek-chat / deepseek-reasoner deprecated 2026-07-24 → map to v4-flash.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_THINKING=disabled

# Logo recognition — local cascade default; external only after cost approval
LOGO_PROVIDER=local
LOGO_EXTERNAL_API_KEY=
LOGO_EXTERNAL_MODEL=
LOGO_EXTERNAL_ENDPOINT=
LOGO_MIN_CONFIDENCE_DEFAULT=0.72

# Social / X — official API only; never scrape. Live off until checklist complete.
X_API_MODE=fixture
X_API_LIVE_ENABLED=false
X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com/2
X_API_USER_AGENT=NewsFetcherBot/0.1 (+https://newsfetcher.local)

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
